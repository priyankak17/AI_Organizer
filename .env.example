# Google Gemini API key, powers the AI buttons (unstick me, meditation nudge, reads, insta ideas).
# Get one free at https://aistudio.google.com/app/apikey  (free tier, no credit card)
# Search grounding for the "find me a read" and insta buttons is built in, nothing extra to enable.
# Note: on the free tier Google may use your prompts to improve their models, so keep sensitive data out.
GEMINI_API_KEY=

# Upstash Redis, your data store. Free tier is plenty for one person.
# Easiest path: in Vercel, add the Upstash (Redis) integration from the Marketplace and these two get injected for you.
# Or sign up at https://upstash.com, create a Redis database, and copy the REST URL and token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional. Set any password to lock the app behind a login screen.
# Leave it blank and the app runs in open mode (anyone with the link can see your data).
APP_PASSWORD=
